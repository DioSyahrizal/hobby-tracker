          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/items", "host": ["{{baseUrl}}"], "path": ["api", "items"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"game\",\n  \"title\": \"Final Fantasy VII Rebirth\"\n}"
