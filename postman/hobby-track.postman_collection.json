            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/items", "host": ["{{baseUrl}}"], "path": ["api", "items"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"gunpla\",\n  \"title\": \"RG Nu Gundam\",\n  \"priority\": 2,\n  \"notes\": \"Bought at Akiba\"\n}"
