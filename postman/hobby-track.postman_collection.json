                  "pm.test('defaults: status=wishlist, priority=3', () => {",
                  "  pm.expect(body.status).to.eql('wishlist');",
                  "  pm.expect(body.priority).to.eql(3);",
                  "});",
                  "pm.test('null date side-effect fields', () => {",
                  "  pm.expect(body.startedAt).to.be.null;",
                  "  pm.expect(body.completedAt).to.be.null;",
                  "  pm.expect(body.lastTouchedAt).to.be.null;",
                  "});",
                  "pm.collectionVariables.set('itemId', body.id);",
                  "console.log('Saved itemId =', body.id);"
                ]
              }
