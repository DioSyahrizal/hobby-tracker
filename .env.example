# ── Database ──────────────────────────────────────────────────────────────────
# Local socket (recommended on VPS): postgres:///hobby_track
# TCP:                                postgres://user:pass@localhost:5432/hobby_track
DATABASE_URL=postgres://user:pass@localhost:5432/hobby_track

# ── Auth ──────────────────────────────────────────────────────────────────────
APP_PASSWORD=change-me
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ── Server ────────────────────────────────────────────────────────────────────
# NOTE: In production PORT and NODE_ENV are managed by PM2 (ecosystem.config.cjs)
#       and do NOT need to be set here. They are listed for local dev only.
NODE_ENV=development
PORT=3002

# ── External APIs ─────────────────────────────────────────────────────────────
RAWG_API_KEY=           # get a free key at https://rawg.io/apidocs
# Jikan (MyAnimeList wrapper): no key needed
GOOGLE_BOOKS_API_KEY=   # optional — increases quota
